    "FullName": "\u0426\u0430\u043B\u043B\u0430\u0433\u043E\u0432 \u0413\u0435\u043E\u0440\u0433\u0438\u0439 \u041A\u0430\u0437\u0431\u0435\u043A\u043E\u0432\u0438\u0447",
    "Description": "\u0412\u0440\u0430\u0447-\u0445\u0438\u0440\u0443\u0440\u0433 \u0432\u044B\u0441\u0448\u0435\u0439 \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0438, \u0437\u0430\u0432\u0435\u0434\u0443\u044E\u0449\u0438\u0439 \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u0435\u043C",
    "Biography": "\u0420\u043E\u0434\u0438\u043B\u0441\u044F 3 \u0444\u0435\u0432\u0440\u0430\u043B\u044F 1975 \u0433\u043E\u0434\u0430 \u0432\u043E \u0412\u043B\u0430\u0434\u0438\u043A\u0430\u0432\u043A\u0430\u0437\u0435. \u0417\u0430\u0432\u0435\u0434\u0443\u044E\u0449\u0438\u0439 \u0445\u0438\u0440\u0443\u0440\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u0435\u043C \u0420\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0430\u043D\u0441\u043A\u043E\u0439 \u043A\u043B\u0438\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0431\u043E\u043B\u044C\u043D\u0438\u0446\u044B. \u041F\u0440\u043E\u0432\u0451\u043B \u0431\u043E\u043B\u0435\u0435 2000 \u0443\u0441\u043F\u0435\u0448\u043D\u044B\u0445 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0439.",
