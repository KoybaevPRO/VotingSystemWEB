    "FullName": "\u0422\u0435\u0434\u0435\u0435\u0432 \u0410\u043B\u0430\u043D \u0421\u043E\u0441\u043B\u0430\u043D\u043E\u0432\u0438\u0447",
    "Description": "\u0418\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u0434\u0435\u044F\u0442\u0435\u043B\u044C \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u044B \u041E\u0441\u0435\u0442\u0438\u0438, \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0442\u043E\u0440 \u0444\u0435\u0441\u0442\u0438\u0432\u0430\u043B\u0435\u0439",
    "Biography": "\u0420\u043E\u0434\u0438\u043B\u0441\u044F 15 \u043C\u0430\u0440\u0442\u0430 1978 \u0433\u043E\u0434\u0430 \u0432\u043E \u0412\u043B\u0430\u0434\u0438\u043A\u0430\u0432\u043A\u0430\u0437\u0435. \u0417\u0430\u0441\u043B\u0443\u0436\u0435\u043D\u043D\u044B\u0439 \u0434\u0435\u044F\u0442\u0435\u043B\u044C \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432 \u0420\u0421\u041E-\u0410\u043B\u0430\u043D\u0438\u044F. \u041E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0442\u043E\u0440 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u044B\u0445 \u043C\u0435\u0440\u043E\u043F\u0440\u0438\u044F\u0442\u0438\u0439 \u0432 \u0440\u0435\u0433\u0438\u043E\u043D\u0435.",
